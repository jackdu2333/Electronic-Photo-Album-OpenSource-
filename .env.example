# ====================
# 电子相框 - 环境配置模板
# ====================
# 复制此文件为 .env 并根据实际情况修改

# ----------------------
# 基础配置
# ----------------------
# 调试模式（生产环境设为 false）
FLASK_DEBUG=false

# Flask 会话加密密钥（建议使用随机字符串，不要泄露！）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-me

# ----------------------
# 用户认证
# ----------------------
# 管理员账户（格式：用户名：密码，多用户用逗号分隔）
# 密码要求：至少 8 位，包含大小写字母，包含数字或特殊字符
# 首次运行时，密码会被自动哈希存储
ADMIN_USERS=admin:ChangeMe123!

# 密码哈希格式（推荐在生产环境使用）
# 生成密码哈希：python -c "from auth import hash_password; print(hash_password('YourPassword123!'))"
# ADMIN_USERS_HASH=admin:$pbkdf2-sha256$...

# ----------------------
# 宝宝/家庭配置（可选）
# ----------------------
# 宝宝昵称（留空则不显示年龄信息，例如：宝宝）
BABY_NAME=

# 宝宝出生日期（格式：YYYY-MM-DD）
BABY_BIRTHDAY=

# ----------------------
# 天气配置
# ----------------------
# 天气坐标（纬度，经度）- 默认苏州
# 查询方法：访问 https://www.latlong.net/ 获取你所在位置的坐标
WEATHER_LAT=31.3041
WEATHER_LON=120.5954

# 是否启用天气显示（true/false）
WEATHER_ENABLED=true

# ----------------------
# 照片推荐算法配置
# ----------------------
# 标签权重（格式：标签：权重，多个用逗号分隔）
# 权重越高，该标签的照片被展示的概率越大
TAG_WEIGHTS=宝宝：1.8，露营：1.5，旅行：1.3

# 季节权重
# current: 当月照片权重
# adjacent: 相邻月份照片权重
# other: 其他月份照片权重
# none: 无日期照片权重
SEASONAL_WEIGHT_CURRENT=1.8
SEASONAL_WEIGHT_ADJACENT=1.4
SEASONAL_WEIGHT_OTHER=0.85
SEASONAL_WEIGHT_NONE=0.5

# 深海打捞概率（0-1 之间，默认 0.05 = 5%）
DEEP_SEA_PROBABILITY=0.05

# 深海打捞阈值（照片拍摄超过多少年算老照片，默认 2 年）
DEEP_SEA_YEARS_THRESHOLD=2

# ----------------------
# 上传配置
# ----------------------
# 最大上传大小（MB）
MAX_UPLOAD_SIZE_MB=200

# 压缩目标大小（MB）
COMPRESS_TARGET_SIZE_MB=3

# 最大分辨率（像素，长边上限）
MAX_RESOLUTION_PX=3840

# ----------------------
# 幻灯片配置
# ----------------------
# 每张照片展示时长（秒，默认 300 秒 = 5 分钟）
SLIDE_DURATION_SECONDS=300

# ----------------------
# 数据库配置
# ----------------------
# 数据库文件路径（相对于项目根目录）
DATABASE_FILE=photos.db

# SQLite 锁等待时间（毫秒）
# 多个请求同时读写数据库时，先等待这段时间再报 "database is locked"
SQLITE_BUSY_TIMEOUT_MS=10000

# 元数据文件路径
METADATA_FILE=photo_metadata.json

# 留言板文件路径
MESSAGES_FILE=messages.json

# ----------------------
# 日志配置
# ----------------------
# 日志文件最大大小（MB）
LOG_MAX_SIZE_MB=10

# 日志备份数量
LOG_BACKUP_COUNT=5
